pipeline {

    agent any

    environment {
    IMAGE_NAME = "task-tracker"
    IMAGE_TAG = "${BUILD_NUMBER}"
    LATEST_TAG = "latest"
    CONTAINER_NAME = "task-tracker"
}

    stages {

        stage('SCM Pull') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies and Run Tests') {
    steps {
        sh '''
        npm install
        npm test
        '''
    }
}

        stage('Build Docker Image') {
    steps {
        sh '''
        docker build \
        --cache-from ${IMAGE_NAME}:latest \
        -t ${IMAGE_NAME}:${IMAGE_TAG} \
        -t ${IMAGE_NAME}:latest .
        '''
    }
}

       stage('Deploy') {
            steps {
                sh '''
                # Stop and remove the old container if it exists, without failing the build
                docker stop ${CONTAINER_NAME} || true
                docker rm ${CONTAINER_NAME} || true
                
                # Run the newly built container (assuming port 3000)
                docker run -d --name ${CONTAINER_NAME} -p 3000:3000 ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

stage('Wait for Application') {
    steps {
        sh '''
        for i in {1..20}
        do
            if curl -f http://localhost:3000/health
            then
                echo "Application is ready"
                exit 0
            fi

            echo "Waiting for application..."
            sleep 5
        done

        exit 1
        '''
    }
}

stage('Curl Verification') {
    steps {
        sh '''
        echo "========== ROOT =========="
        curl http://localhost:3000/

        echo ""

        echo "========== HEALTH =========="
        curl http://localhost:3000/health

        echo ""

        echo "========== TASKS =========="
        curl http://localhost:3000/api/tasks
        '''
    }
}
}
    post {

        always {

            sh '''
            echo "Cleaning up..."

            docker compose down || true

            docker image prune -f

            docker container prune -f

            docker system prune -f

            '''

            cleanWs()
        }

    }
}



